[user]
	name  = {{NAME}}
	email = {{EMAIL}}

[core]
	editor = nvim
	pager  = delta

[interactive]
	diffFilter = delta --color-only

[delta]
	navigate    = true
	dark        = true
	side-by-side = true

[diff]
	colorMoved = default

[merge]
	conflictstyle = diff3

[init]
	defaultBranch = main

[push]
	autoSetupRemote = true

[pull]
	rebase = false
